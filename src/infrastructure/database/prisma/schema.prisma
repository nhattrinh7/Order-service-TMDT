generator client {
  provider = "prisma-client-js"
}

// prisma tự động đọc file .env dù cho chưa cài .dotenv, nhưng chỉ đọc được giá trị 
// trong env khi prisma đã start lên, những chỗ chưa start thì chịu
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_PAYMENT
  AWAITING_CONFIRMATION
  PREPARING
  SHIPPING
  DELIVERY_COMPLETED
  DELIVERY_FAILED
  ORDER_FAILED // luồng ko thành công ở đoạn nào đó khác đoạn payment
  CANCELLED // đặt hàng rồi mà buyer sau đó hủy đơn
  RETURNED // chắc mình ko làm cái trả hàng hoàn tiền này
  PAYMENT_FAILED // saga step mà fail đúng đoạn thanh toán thì mới chọn status này
}

// COD: AWAITING_CONFIRMATION ngay
// Online - thành công: PENDING_PAYMENT → thanh toán OK → AWAITING_CONFIRMATION
// Online - thất bại: PENDING_PAYMENT → thanh toán thất bại → PAYMENT_FAILED
// COD thì shipper giao hàng và thu tiền hộ thành công + người mua nhấn đã nhận dc hàng (hoặc timeout 3 ngày)
// mới chuyển status sang DELIVERY_COMPLETED, thanh toán online thì shipper giao 
// thành công và người mua nhấn đã nhận dc hàng (hoặc timeout 3 ngày) là đã ok r và chuyển sang DELIVERY_COMPLETED dc rồi

enum OrderPaymentMethod {
  COD
  WALLET
  QRCODE
}

model Order {
  id                   String             @id @default(uuid()) @db.Uuid
  // paymentId có giá trị khi đơn hàng thanh toán QRCODE thành công, không có giá trị khi
  // người dùng chọn thanh toán COD hoặc WALLET
  paymentId            String?            @map("payment_id") @db.Uuid
  userId               String             @map("user_id") @db.Uuid
  shopId               String             @map("shop_id") @db.Uuid
  status               OrderStatus        @default(AWAITING_CONFIRMATION)
  paymentMethod        OrderPaymentMethod @map("payment_method")
  shippingAddress      String             @map("shipping_address")
  receiverName         String             @map("receiver_name")
  receiverPhoneNumber  String             @map("receiver_phone_number")
  subtotal             Int // Tổng tiền chưa giảm giá
  shippingFee          Int                @map("shipping_fee") // Cố định là 1000
  szoneVoucherDiscount Int                @default(0) @map("szone_voucher_discount")
  shopVoucherDiscount  Int                @default(0) @map("shop_voucher_discount")
  goodsPrice           Int                @map("goods_price")
  finalPrice           Int                @map("final_price")
  cancelReason         String?            @map("cancel_reason") @db.Text
  qrCode               String?            @map("qr_code") @db.Text
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  orderItems OrderItem[]
  settlement Settlement?

  @@map("orders")
}

model OrderItem {
  id               String @id @default(uuid()) @db.Uuid
  orderId          String @map("order_id") @db.Uuid
  productId        String @map("product_id") @db.Uuid
  productVariantId String @map("product_variant_id") @db.Uuid
  productName      String @map("product_name")
  variantImage     String @map("variant_image") @db.Text
  sku              String // Nâu-XL
  quantity         Int
  finalPrice       Int // Giá 1 đơn vị tại thời điểm mua (đã tính vouchers)
  returnReason     String? @map("return_reason") @db.Text
  returnStatus     OrderItemReturnStatus @default(NONE) @map("return_status")
  returnRequestedAt DateTime? @map("return_requested_at")
  returnResolvedAt  DateTime? @map("return_resolved_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

enum OrderItemReturnStatus {
  NONE
  REFUNDED
}

// Sau khi shipper giao hàng thành công sẽ tạo bản ghi Settlement, shipper giao thành công sẽ gửi api chứa orderId lên BE
// dùng orderId này để lấy ra bản ghi Order và dùng dữ liệu từ bản ghi Order này để tạo bản ghi Settlement
// commissionFee = goodsPrice * 5%
// payout = finalPrice - commissionFee
// Đơn hàng giao thất bại thì ko tạo bản ghi Settlement, người mua được refund nếu đã thanh toán và sản phẩm được hoàn về shop.
model Settlement {
  id            String        @id @default(uuid()) @db.Uuid
  orderId       String        @unique @map("order_id") @db.Uuid
  shopId        String        @map("shop_id") @db.Uuid
  goodsPrice    Int           @map("goods_price")
  finalPrice    Int           @map("final_price")
  shippingFee   Int           @map("shipping_fee")
  commissionFee Int           @map("commission_fee")
  payout        Int
  paymentMethod PaymentMethod @default(WALLET) @map("payment_method")
  status        PayoutStatus  @default(PENDING)
  payoutAt      DateTime?     @map("payout_at") @db.Timestamptz
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id])
 
  @@map("settlements")
}

enum PaymentMethod {
  WALLET
}

enum PayoutStatus {
  PENDING // Chưa cộng vào ví seller
  COMPLETED // Đã cộng vào ví seller
}

model TransitWarehouse {
  id        String @id @default(uuid()) @db.Uuid
  scannerId String @unique @map("scanner_id") @db.Uuid
  name      String @unique @db.VarChar(255)
  address   String @db.Text

  @@map("transit_warehouses")
}

model OrderDeliveryHistory {
  id         String @id @default(uuid()) @db.Uuid
  orderId    String @map("order_id") @db.Uuid
  warehouses Json?  @map("warehouse_history")
  shipper    Json?

  @@map("order_delivery_histories")
}

